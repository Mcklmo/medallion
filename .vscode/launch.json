{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Test all",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "python": "${command:python.interpreterPath}",
            "args": [],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Test specific",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "python": "${command:python.interpreterPath}",
            "args": [
                "--maxfail=1",
                "--disable-warnings",
                "-q",
                "${input:testFile}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
        },
        {
            "name": "CLI: Run User Pipeline (example)",
            "type": "debugpy",
            "request": "launch",
            "module": "medallion.medallion",
            "python": "${command:python.interpreterPath}",
            "args": "${input:pipelineClasses}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "MEDALLION_ROOT": "${workspaceFolder}/example"
            },
            "justMyCode": false
        },
        {
            "name": "Code: Run User Pipeline (example)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/example/basic/run.py",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "MEDALLION_ROOT": "${workspaceFolder}/example"
            },
            "justMyCode": false
        },
        {
            "name": "Run horde (example)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/example/streaming/run.py",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "MEDALLION_ROOT": "${workspaceFolder}/example"
            },
            "justMyCode": false
        },
        {
            "name": "Trigger extractor (example)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/example/streaming/trigger_mock.py",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "MEDALLION_ROOT": "${workspaceFolder}/example"
            },
            "justMyCode": false
        }
    ],
    "inputs": [
        {
            "id": "pipelineClasses",
            "type": "promptString",
            "description": "Pipeline classes",
            "default": "Extractor Transformer"
        },
        {
            "id": "testFile",
            "type": "promptString",
            "description": "Test file to run (relative to workspace)",
            "default": "test/test_horde.py"
        }
    ]
}